# Virtual environment — contains every installed package, machine-specific paths
venv/

# Python cache — auto-regenerated bytecode, never needed in source control
__pycache__/
*.pyc
*.pyo

# Secrets — your real Gemini API key lives here, must NEVER be public
.env

# FAISS vector index — generated from your documents, not source code
faiss_index/

# LlamaIndex storage — same reasoning as faiss_index/
llama_index_storage/

# Uploaded files — user-uploaded documents, not part of the codebase
uploads/

# Auto-generated comparison output (Day 11)
comparison_notes.json

# HuggingFace model cache (if you ever point it locally instead of system cache)
.cache/

# OS-generated junk files
.DS_Store
Thumbs.db

# Docker volumes data (if any get created locally outside the mapped folders)
*.log